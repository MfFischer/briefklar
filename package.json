{
  "name": "briefklar",
  "version": "0.1.0",
  "description": "Scan any German letter. Know exactly what to do. Never miss a deadline.",
  "main": "out/main/index.js",
  "homepage": "./",
  "author": "BriefKlar",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build:win": "node scripts/build.js --win",
    "build:mac": "node scripts/build.js --mac",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "node-schedule": "^2.1.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.4",
    "tesseract.js": "^5.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.5",
    "@types/node-schedule": "^2.1.7",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.briefklar.app",
    "productName": "BriefKlar",
    "copyright": "Copyright © 2026 Maria Fe Fischer",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "knowledge-base/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/tessdata",
        "to": "tessdata",
        "filter": ["*.traineddata"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BriefKlar"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
